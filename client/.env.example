# ============================================================
# MarketHub - CLIENT environment variables
# Copy this file to ".env.local" (Next.js reads .env.local)
# ============================================================

# URL of your backend API (REQUIRED)
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# Base URL of backend (used for socket.io connection)
NEXT_PUBLIC_SOCKET_URL=http://localhost:5000

# Google OAuth Client ID (OPTIONAL - leave blank to hide Google button)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
