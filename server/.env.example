# ============================================================
# MarketHub - SERVER environment variables
# Copy this file to ".env" and fill in your own values.
# The app RUNS even if you leave the optional ones blank
# (it falls back to a safe demo mode). See README for details.
# ============================================================

# ---- REQUIRED ----
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# MongoDB Atlas connection string (REQUIRED).
# Get a free one at https://www.mongodb.com/cloud/atlas
# Example: mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/markethub
MONGODB_URI=mongodb://127.0.0.1:27017/markethub

# JWT secrets (REQUIRED) - put any long random strings here
JWT_ACCESS_SECRET=replace_this_with_a_long_random_string_123
JWT_REFRESH_SECRET=replace_this_with_a_different_long_random_string_456
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# ---- OPTIONAL (app works without these in demo mode) ----

# Email (Nodemailer SMTP). If blank, OTP/reset codes are printed
# to the server console AND returned in the API response (dev only).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=MarketHub <no-reply@markethub.dev>

# Cloudinary (image upload). If blank, images are saved to /uploads locally.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Stripe. If blank, checkout uses a MOCK success that creates the order.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Google OAuth (login with Google). If blank, the Google button is disabled.
GOOGLE_CLIENT_ID=
